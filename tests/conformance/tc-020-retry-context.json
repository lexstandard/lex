  "id": "TC-020",
  "title": "Retry Context on Retransmission",
  "level": "L3",
  "conformanceLevel": 3,
  "category": "TRANSPORT_RESILIENCE",
  "description": "LEAD message carries header.retryContext.attemptNumber=3, indicating this is the third delivery attempt of an original message. The receiver MUST process the message idempotently — if a record with this messageId already exists, no duplicate lead MUST be created. retryContext is informational and MUST NOT cause rejection.",
