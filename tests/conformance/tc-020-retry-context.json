        "timestamp": "2026-04-03T10:19:00Z",
        "senderId": "PORTAL-001",
        "receiverId": "DEALER-001",
        "retryContext": {
          "originalTimestamp": "2026-04-03T09:50:00Z",
          "attemptNumber": 3,
          "maxAttempts": 6
        }
      },
      "payload": {
