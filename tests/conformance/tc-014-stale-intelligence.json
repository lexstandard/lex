        "messageType": "LEAD",
        "version": "1.0",
        "timestamp": "2026-04-03T10:13:00Z",
        "senderId": "PORTAL-001",
        "receiverId": "DEALER-001"
      },
      "payload": {
        "lead": {
          "leadId": "LEAD-TC014-0001",
          "status": "EXPRESSED_INTEREST",
          "source": "THIRD_PARTY_PORTAL",
          "customer": {
            "firstName": "James",
            "lastName": "Park",
            "emailAddress": "j.park@example.com",
            "phoneNumber": "+12135550128"
          },
          "desiredProduct": {
            "productType": "VEHICLE_NEW",
