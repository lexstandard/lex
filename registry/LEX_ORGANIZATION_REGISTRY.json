  "registrationGuidelines": {
    "description": "Guidelines for registering new organization schemas",
    "steps": [
      "1. Contact LEX support with organization details",
      "2. Define schema fields with types and validation rules",
      "3. Submit schema in JSON format for review",
      "4. Receive API key for programmatic access",
      "5. Test schema in sandbox environment",
      "6. Schema approved and moved to production"
    ],
    "schemaRequirements": {
      "mandatory": [
        "schemaId (unique, format: ORG-DESCRIPTION-VERSION)",
        "schemaName (human-readable)",
        "version (semantic versioning)",
        "purpose (use case description)",
        "fields array with complete field definitions"
      ],
      "fieldRequirements": [
        "fieldName (alphanumeric, snake_case)",
        "fieldType (string, integer, boolean, date, datetime, number, uri)",
        "description (clear usage documentation)",
        "required (boolean, default false)",
        "validation (patterns, enums, min/max, custom rules as needed)"
      ]
    },
    "bestPractices": [
      "Use clear, descriptive field names",
      "Document all enum values with descriptions",
      "Include regex patterns for text fields",
      "Set reasonable min/max values for numeric fields",
      "Mark fields as required only when necessary",
      "Avoid redundancy with standard LEX fields",
      "Test schema with sample data before production",
      "Version schemas for backwards compatibility"
    ]
  },
  "commonSchemaPatterns": {
    "retailerContext": {
      "description": "Context data managed by DMS systems",
      "fields": ["dealershipId", "salesPersonId", "followUpScheduled", "assignedQueue"]
    },
    "manufacturerContext": {
      "description": "Manufacturer-specific lead scoring and routing",
      "fields": ["manufacturerLeadScore", "regionAssignment", "modelPreference", "loyaltyHistory"]
    },
    "marketSpecific": {
      "description": "Market-specific compliance and preferences",
      "examples": [
        "India: Aadhaar verification, subsidy eligibility, payment methods",
        "EU: GDPR consent, regional compliance",
        "USA: State regulations, credit requirements"
      ]
    },
    "productSpecific": {
      "description": "Product-type-specific attributes",
      "examples": [
        "Vehicle: Engine, transmission, features",
        "Motorcycle: Category, displacement, rider experience",
        "E-bike: Motor brand, cargo capacity, battery type",
        "Scooter: Range, battery type, charging compatibility"
      ]
    }
  },
  "apiEndpoints": {
    "registerSchema": "POST /api/v1/registry/schemas",
    "updateSchema": "PUT /api/v1/registry/schemas/{schemaId}",
    "getSchema": "GET /api/v1/registry/schemas/{schemaId}",
    "listSchemas": "GET /api/v1/registry/schemas?organizationId=ORG-ID",
    "validateAgainstSchema": "POST /api/v1/registry/validate/{schemaId}",
    "getRegistry": "GET /api/v1/registry"
  },
  "supportedFieldTypes": [
    "string (max 500 chars default)",
    "integer (32-bit)",
    "number (floating point)",
    "boolean",
    "date (ISO 8601)",
    "datetime (ISO 8601)",
    "uri (URL format)",
    "email",
    "phone",
    "enum (predefined values)",
    "array (homogeneous)",
    "object (nested fields)"
  ],
  "notes": {
    "governance": "Each organization maintains their own schemas independently",
    "compatibility": "Schemas must align with LEX message structure to be valid",
    "security": "API keys are required for programmatic access",
    "rateLimit": "Registry API is rate-limited to 1000 requests per minute per organization",
    "versioning": "Use semantic versioning (major.minor) for schema updates",
    "deprecation": "Deprecated schemas may be marked but are kept for backward compatibility"
  }
}
